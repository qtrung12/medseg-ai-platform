# ========== ENVIRONMENT ==========
ENV=development

# ========== DATABASE CONFIG ==========
# Connection string để kết nối PostgreSQL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://medseg:medseg123@localhost:5432/medseg_db

# ========== REDIS CONFIG ==========
# Redis connection string cho caching và message broker
REDIS_URL=redis://localhost:6379/0

# ========== MINIO CONFIG ==========
# MinIO object storage connection
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=medseg-ai

# ========== API CONFIG ==========
# FastAPI server configuration
API_HOST=0.0.0.0
API_PORT=8000

# ========== CORS CONFIG ==========
# Allowed origins cho CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ========== JWT CONFIG (For Future Use) ==========
# Secret key để sign JWT tokens - CHANGE THIS IN PRODUCTION
SECRET_KEY=your_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== MODEL SERVER CONFIG ==========
# URL của model_server service để gửi inference requests
MODEL_SERVER_URL=http://localhost:8001
